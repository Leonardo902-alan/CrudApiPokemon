<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        style="@style/Widget.App.Toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:navigationIcon="@drawable/ic_back"
        app:title="@string/titulo_detalle" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/spacing_xxl"
        android:indeterminateTint="@color/primary"
        android:visibility="gone" />

    <ScrollView
        android:id="@+id/contenidoDetalle"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        android:visibility="gone"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/spacing_xxl">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:background="@drawable/bg_hero_gradient">

                <ImageView
                    android:id="@+id/ivSprite"
                    android:layout_width="@dimen/avatar_xl"
                    android:layout_height="@dimen/avatar_xl"
                    android:layout_gravity="center"
                    android:contentDescription="@string/titulo_detalle"
                    android:scaleType="fitCenter"
                    tools:src="@drawable/ic_pokeball" />

            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="@dimen/screen_horizontal"
                android:paddingTop="@dimen/spacing_lg"
                android:paddingEnd="@dimen/screen_horizontal">

                <TextView
                    android:id="@+id/tvNombre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.App.LargeTitle"
                    tools:text="Pikachu" />

                <TextView
                    android:id="@+id/tvNumero"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:textAppearance="@style/TextAppearance.App.Subhead"
                    tools:text="#25" />

                <TextView
                    android:id="@+id/tvTipos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:background="@drawable/bg_type_chip"
                    android:paddingStart="14dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="6dp"
                    android:textAppearance="@style/TextAppearance.App.Subhead"
                    android:textColor="@color/tipo_chip_text"
                    tools:text="Eléctrico" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/screen_horizontal"
                android:layout_marginTop="@dimen/spacing_xl"
                android:layout_marginEnd="@dimen/screen_horizontal"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:text="@string/seccion_info"
                android:textAllCaps="true"
                android:textAppearance="@style/TextAppearance.App.Footnote"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/screen_horizontal"
                android:layout_marginEnd="@dimen/screen_horizontal"
                android:background="@drawable/bg_grouped_card"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <TextView
                    android:id="@+id/tvAltura"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="@dimen/spacing_sm"
                    android:paddingBottom="@dimen/spacing_sm"
                    android:textAppearance="@style/TextAppearance.App.Body"
                    tools:text="Altura: 0.4 m" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/separator" />

                <TextView
                    android:id="@+id/tvPeso"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="@dimen/spacing_sm"
                    android:paddingBottom="@dimen/spacing_sm"
                    android:textAppearance="@style/TextAppearance.App.Body"
                    tools:text="Peso: 6.0 kg" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/separator" />

                <TextView
                    android:id="@+id/tvHabilidades"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="@dimen/spacing_sm"
                    android:paddingBottom="@dimen/spacing_sm"
                    android:textAppearance="@style/TextAppearance.App.Body"
                    tools:text="Habilidades: Static" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCapturar"
                style="@style/Widget.App.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/screen_horizontal"
                android:layout_marginTop="@dimen/spacing_xl"
                android:layout_marginEnd="@dimen/screen_horizontal"
                android:text="@string/capturar_pokemon" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
