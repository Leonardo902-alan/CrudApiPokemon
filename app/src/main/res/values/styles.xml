<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.EstudiantesCRUD.Base" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="materialButtonStyle">@style/Widget.App.Button.Primary</item>
        <item name="textInputStyle">@style/Widget.App.TextInput</item>
    </style>

    <style name="Widget.App.Toolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/background</item>
        <item name="titleTextColor">@color/text_primary</item>
        <item name="subtitleTextColor">@color/text_secondary</item>
        <item name="navigationIconTint">@color/primary</item>
        <item name="android:elevation">0dp</item>
        <item name="titleTextAppearance">@style/TextAppearance.App.Headline</item>
    </style>

    <style name="Widget.App.Toolbar.Large" parent="Widget.App.Toolbar">
        <item name="titleTextAppearance">@style/TextAppearance.App.LargeTitle</item>
    </style>

    <style name="TextAppearance.App.LargeTitle" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textSize">@dimen/text_large_title</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.App.Title1" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textSize">@dimen/text_title1</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.App.Title2" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">@dimen/text_title2</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.App.Headline" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textSize">@dimen/text_headline</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.App.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.App.Subhead" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">@dimen/text_subhead</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.App.Footnote" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">@dimen/text_footnote</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="Widget.App.Card.Grouped" parent="">
        <item name="android:background">@drawable/bg_grouped_card</item>
    </style>

    <style name="Widget.App.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/text_headline</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">@dimen/radius_lg</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Widget.App.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/text_subhead</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">@dimen/radius_pill</item>
        <item name="strokeColor">@color/separator</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/primary</item>
        <item name="backgroundTint">@color/fill_secondary</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Widget.App.Button.Destructive" parent="Widget.App.Button.Secondary">
        <item name="android:textColor">@color/error</item>
        <item name="backgroundTint">@color/white</item>
    </style>

    <style name="Widget.App.TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/radius_md</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_md</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_md</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_md</item>
        <item name="boxStrokeColor">@color/separator</item>
        <item name="boxBackgroundColor">@color/white</item>
        <item name="hintTextColor">@color/text_tertiary</item>
    </style>

    <style name="Widget.App.FAB" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/primary</item>
        <item name="tint">@color/white</item>
        <item name="elevation">4dp</item>
        <item name="fabCustomSize">56dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.App.FAB</item>
    </style>

    <style name="ShapeAppearance.App.FAB" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">18dp</item>
    </style>

</resources>
